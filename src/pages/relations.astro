---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />
  <main class="min-h-screen bg-black">
    <section class="relative h-screen w-full overflow-hidden bg-black" style="height: 100dvh;" aria-label="Relations publiques hero">
      <div class="absolute inset-0 z-10">
        <div class="h-full w-full" style="background: radial-gradient(ellipse at 30% 44%, rgba(191,238,255,.08), transparent 22%), radial-gradient(ellipse at 78% 62%, rgba(216,194,255,.06), transparent 28%), #050505;"></div>
      </div>
      <div class="pointer-events-none absolute inset-0 z-20 overflow-hidden" aria-hidden="true">
        <div class="h-full w-full opacity-[0.12]" style="background: radial-gradient(circle at 32% 38%, #bfeeff, transparent 28%), radial-gradient(circle at 72% 54%, #d8c2ff, transparent 24%); filter: blur(80px);"></div>
      </div>
      <div class="hero-scrim pointer-events-none absolute inset-0 z-40" aria-hidden="true" style="background: radial-gradient(circle at 52% 44%, rgba(216,194,255,.06), transparent 28%), linear-gradient(90deg, rgba(0,0,0,.42), rgba(0,0,0,.12) 42%, rgba(0,0,0,.02) 72%, rgba(0,0,0,.28) 100%);"></div>
      <div class="hero-bottom-mask pointer-events-none absolute inset-x-0 bottom-0 z-[45] h-[62vh]" aria-hidden="true"></div>

      <div class="pointer-events-none absolute inset-0 z-50 flex items-end px-5 pb-10 pt-28 sm:px-8 sm:pb-12 md:px-12 lg:pb-14">
        <div class="w-full">
          <div class="flex min-h-0 flex-col justify-end gap-5 lg:max-w-[720px]">
            <div class="hero-anim hero-fade flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.24em] text-white/80 drop-shadow-[0_2px_16px_rgba(0,0,0,0.85)]" style="animation-delay: .18s;"><span class="h-px w-14 bg-[#bfeeff]"></span>Relations Publiques · RP 2.0</div>
            <h1 class="text-white leading-[0.88] drop-shadow-[0_4px_28px_rgba(0,0,0,0.85)]">
              <span class="hero-anim hero-reveal-text block text-5xl font-medium sm:text-6xl md:text-7xl lg:text-[6.6rem]" style="letter-spacing:-.08em;animation-delay:.25s;">Faites parler</span>
              <span class="hero-anim hero-reveal-text -mt-1 block font-playfair text-5xl italic font-normal sm:text-6xl md:text-7xl lg:text-[6.6rem]" style="letter-spacing:-.06em;animation-delay:.42s;">de vous. Vraiment.</span>
            </h1>
            <div class="hero-anim hero-fade max-w-[560px]" style="animation-delay:.68s;">
              <p class="max-w-[500px] text-sm leading-relaxed text-white drop-shadow-[0_3px_22px_rgba(0,0,0,0.95)] sm:text-base md:text-lg">Les Relations Publiques accessibles aux independants et aux PME du Canton de Vaud. Des RP professionnelles, des 80 CHF. Sans contrat annuel. Sans budget d'agence.</p>
              <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
                <a href="#services" class="pointer-events-auto w-fit rounded-full bg-white px-7 py-3 text-sm font-semibold text-black transition-all hover:scale-[1.03] hover:bg-[#effbff] hover:shadow-lg hover:shadow-[#bfeeff]/25 active:scale-95">Decouvrir les services</a>
                <a href="#contact" class="pointer-events-auto w-fit rounded-full border border-white/30 bg-transparent px-7 py-3 text-sm font-semibold text-white backdrop-blur transition-all hover:border-white/55 hover:bg-white/10 active:scale-95">Me contacter</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="vertical-label hero-anim hero-fade pointer-events-none absolute left-4 bottom-10 z-50 hidden text-[10px] font-semibold uppercase tracking-[0.26em] text-white/50 md:block" style="animation-delay:.95s;">ORIANE ANNEN / RELATIONS PUBLIQUES</div>
    </section>

    <div class="site-bg text-white">
      <div class="content-layer">
        <section id="services" class="relative mx-auto max-w-6xl px-5 py-28 sm:px-8 md:py-40">
          <p class="eyebrow reveal"><span class="eyebrow-line"></span> Mes services</p>
          <h2 class="reveal mt-7 text-4xl font-medium tracking-tight sm:text-5xl md:text-6xl lg:text-[4.6rem]" style="letter-spacing:-.055em;">Des RP concuEs <span class="font-playfair italic font-normal">pour vous</span></h2>
          <div class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
            <article class="reveal stagger glass-card group rounded-[2rem] border border-white/10 p-6 md:p-8" style="transition-delay: 0ms;">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/15 bg-white/5"><span class="font-playfair text-3xl italic text-exo-cyan">01</span></div>
              <h3 class="mt-8 font-playfair text-3xl italic">Relations presse</h3>
              <p class="mt-2 text-sm font-semibold uppercase tracking-[.18em] text-white/50">Vos posts vous rendent visible. Un article vous rend credible.</p>
              <ul class="mt-6 space-y-3 text-sm leading-relaxed text-white/60">
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Communiques et dossiers de presse</li>
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Relations avec les journalistes romands</li>
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Placement presse, radio, TV et podcasts</li>
              </ul>
            </article>
            <article class="reveal stagger glass-card group rounded-[2rem] border border-white/10 p-6 md:p-8 md:translate-y-10" style="transition-delay: 90ms;">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/15 bg-white/5"><span class="font-playfair text-3xl italic text-exo-cyan">02</span></div>
              <h3 class="mt-8 font-playfair text-3xl italic">Preparation aux medias</h3>
              <p class="mt-2 text-sm font-semibold uppercase tracking-[.18em] text-white/50">Un journaliste vous appelle. Vous savez quoi repondre ?</p>
              <ul class="mt-6 space-y-3 text-sm leading-relaxed text-white/60">
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Kit media complet, pret a l'emploi</li>
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Messages cles et cadre juridique</li>
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Accompagnement quand un media vous approche</li>
              </ul>
            </article>
            <article class="reveal stagger glass-card group rounded-[2rem] border border-white/10 p-6 md:p-8" style="transition-delay: 180ms;">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/15 bg-white/5"><span class="font-playfair text-3xl italic text-exo-cyan">03</span></div>
              <h3 class="mt-8 font-playfair text-3xl italic">Communication digitale</h3>
              <p class="mt-2 text-sm font-semibold uppercase tracking-[.18em] text-white/50">Etre partout ne sert a rien. Etre au bon endroit change tout.</p>
              <ul class="mt-6 space-y-3 text-sm leading-relaxed text-white/60">
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Gestion des reseaux sociaux</li>
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Strategie digitale sur mesure</li>
                <li class="flex items-start gap-3"><span class="mt-1 h-1 w-1 shrink-0 rounded-full bg-exo-cyan"></span>Contenus qui vous ressemblent</li>
              </ul>
            </article>
          </div>
        </section>

        <div class="section-line mx-auto h-px max-w-6xl"></div>

        <section class="relative mx-auto max-w-6xl px-5 py-28 sm:px-8 md:py-40">
          <div class="grid gap-12 lg:grid-cols-[.95fr_1.05fr] lg:items-center">
            <div>
              <p class="eyebrow reveal"><span class="eyebrow-line"></span> Pourquoi les RP ?</p>
              <h2 class="reveal mt-8 max-w-4xl text-4xl font-medium leading-[1.02] tracking-tight sm:text-5xl md:text-6xl lg:text-[4.6rem]" style="letter-spacing:-.055em;">
                <span class="text-mask"><span>Les reseaux vous rendent visible.</span></span>
                <span class="text-mask"><span>La pub vous rend connu.</span></span>
                <span class="text-mask font-playfair italic font-normal text-white/90"><span>Les medias vous rendent credible.</span></span>
              </h2>
            </div>
            <div class="reveal glass-card rounded-[2rem] border border-white/10 p-6 sm:p-8">
              <p class="text-base leading-relaxed text-white/65 md:text-lg">Quand un journal, une radio ou un podcast parle de vous, tout change : ce n'est plus vous qui dites que vous etes bon — c'est un tiers de confiance. Et ce jour-la, ce sont vos clients qui viennent a vous.</p>
              <div class="mt-8 flex flex-wrap gap-6 border-t border-white/10 pt-6">
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[.24em] text-white/40">Le probleme</p>
                  <p class="mt-2 text-sm text-white/60">Les agences RP facturent plusieurs milliers de francs par mois. Hors de portee d'un commerce, d'un artisan, d'une PME.</p>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[.24em] text-exo-cyan">Ma reponse</p>
                  <p class="mt-2 text-2xl font-semibold text-white">Des 80 CHF</p>
                  <p class="text-sm text-white/60">Sans contrat annuel. Sans budget d'agence.</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <div class="section-line mx-auto h-px max-w-6xl"></div>

        <section class="relative mx-auto max-w-6xl px-5 py-28 sm:px-8 md:py-40">
          <div class="reveal flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="eyebrow reveal"><span class="eyebrow-line"></span> Services detailles</p>
              <h2 class="reveal mt-6 text-4xl font-medium tracking-tight sm:text-5xl md:text-6xl" style="letter-spacing:-.055em;">Tarifs et <span class="font-playfair italic font-normal">formules</span></h2>
            </div>
            <p class="reveal max-w-sm text-sm leading-relaxed text-white/55">Des interventions ponctuelles aux abonnements mensuels, chaque service est pense pour les petites structures.</p>
          </div>

          <div class="mt-14 space-y-5">
            <div class="reveal glass-card rounded-[2rem] border border-white/10 p-7 md:p-9">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[.26em] text-exo-cyan">Interventions ponctuelles</p>
                  <h3 class="mt-4 text-3xl font-medium tracking-tight">Service Flash</h3>
                  <p class="mt-4 text-sm leading-relaxed text-white/55">Redaction et diffusion d'un communique de presse, prise de contact avec des journalistes, conseil cible ou gestion d'une situation sensible. Une reponse concrete, professionnelle et rapide, tout en respectant l'image et les valeurs de votre etablissement.</p>
                </div>
                <span class="shrink-0 font-playfair text-4xl italic text-exo-cyan">Des 80 CHF</span>
              </div>
            </div>
            <div class="reveal glass-card rounded-[2rem] border border-white/10 p-7 md:p-9">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[.26em] text-exo-cyan">Abonnements mensuels</p>
                  <h3 class="mt-4 text-3xl font-medium tracking-tight">Relations Publiques dans la duree</h3>
                  <div class="mt-4 grid gap-4 sm:grid-cols-2">
                    <div><p class="font-semibold">Relations presse au mois</p><p class="mt-1 text-sm text-white/55">Chaque mois : recherche d'angles, redaction et diffusion de communiques, demarchage des medias pertinents.</p></div>
                    <div><p class="font-semibold">Reseaux sociaux</p><p class="mt-1 text-sm text-white/55">Gestion de votre presence en ligne : publications regulieres, coherence, suivi. Contenu et rythme definis ensemble.</p></div>
                  </div>
                </div>
                <span class="shrink-0 font-playfair text-4xl italic text-exo-cyan">Des 250 CHF/mois</span>
              </div>
            </div>
            <div class="reveal glass-card rounded-[2rem] border border-white/10 p-7 md:p-9">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[.26em] text-exo-cyan">Projets sur-mesure</p>
                  <h3 class="mt-4 text-3xl font-medium tracking-tight">Campagne de A a Z</h3>
                  <p class="mt-4 text-sm leading-relaxed text-white/55">De la reflexion strategique a la mise en oeuvre : analyse, definition des messages, strategie et budget, planification, suivi des retombees, evaluation et repositionnement. Exemple : lancement d'un food truck avec analyse du territoire, communique de presse, recherche de partenaires et journee degustation presse.</p>
                </div>
                <span class="shrink-0 font-playfair text-4xl italic text-white/55">Sur devis</span>
              </div>
            </div>
          </div>
        </section>

        <div class="section-line mx-auto h-px max-w-6xl"></div>

        <section id="faq" class="relative mx-auto max-w-3xl px-5 py-24 sm:px-8 md:py-32">
          <p class="eyebrow reveal"><span class="eyebrow-line"></span> FAQ</p>
          <h2 class="reveal mt-7 text-4xl font-medium tracking-tight sm:text-5xl md:text-6xl" style="letter-spacing:-.055em;">Questions <span class="font-playfair italic font-normal">frequentes</span></h2>
          <div class="mt-12 divide-y divide-white/10 border-y border-white/10">
            <div class="faq-item reveal"><button class="faq-toggle flex w-full items-center justify-between gap-6 py-7 text-left" type="button"><span class="text-lg font-medium tracking-tight">Que faites-vous exactement en relations publiques ?</span><iconify-icon icon="solar:add-circle-linear" width="24" class="faq-icon shrink-0 text-exo-cyan"></iconify-icon></button><div class="faq-body"><p class="pb-7 pr-10 text-sm leading-relaxed text-white/60">Je cree des connexions entre votre entreprise et les bons medias, journalistes et interlocuteurs cles. Je valorise votre image, gere vos communications sensibles, redige vos contenus presse et vous aide a etre vu, entendu et compris.</p></div></div>
            <div class="faq-item reveal"><button class="faq-toggle flex w-full items-center justify-between gap-6 py-7 text-left" type="button"><span class="text-lg font-medium tracking-tight">Comment se deroule une collaboration ?</span><iconify-icon icon="solar:add-circle-linear" width="24" class="faq-icon shrink-0 text-exo-cyan"></iconify-icon></button><div class="faq-body"><p class="pb-7 pr-10 text-sm leading-relaxed text-white/60">Nous commencons par un echange pour comprendre vos objectifs. Ensuite, je construis une strategie RP personnalisee : messages cles, ciblage medias, opportunites journalistiques, calendrier d'actions et suivi regulier transparent.</p></div></div>
            <div class="faq-item reveal"><button class="faq-toggle flex w-full items-center justify-between gap-6 py-7 text-left" type="button"><span class="text-lg font-medium tracking-tight">Travaillez-vous avec tous les types d'entreprises ?</span><iconify-icon icon="solar:add-circle-linear" width="24" class="faq-icon shrink-0 text-exo-cyan"></iconify-icon></button><div class="faq-body"><p class="pb-7 pr-10 text-sm leading-relaxed text-white/60">Oui, tant qu'il existe une histoire authentique a raconter. Je travaille avec des structures locales, regionales, associations, PME ou independants — l'important est l'humain et la coherence.</p></div></div>
            <div class="faq-item reveal"><button class="faq-toggle flex w-full items-center justify-between gap-6 py-7 text-left" type="button"><span class="text-lg font-medium tracking-tight">Pouvez-vous aussi aider avec les reseaux sociaux ?</span><iconify-icon icon="solar:add-circle-linear" width="24" class="faq-icon shrink-0 text-exo-cyan"></iconify-icon></button><div class="faq-body"><p class="pb-7 pr-10 text-sm leading-relaxed text-white/60">Oui. Grace a ma formation en marketing digital et a ma vision 360° de la communication, j'integre des conseils social media bienveillants dans mes services : contenu coherent, posture, lignes editoriales et gestion responsable.</p></div></div>
            <div class="faq-item reveal"><button class="faq-toggle flex w-full items-center justify-between gap-6 py-7 text-left" type="button"><span class="text-lg font-medium tracking-tight">Comment gerez-vous une crise ou des avis negatifs ?</span><iconify-icon icon="solar:add-circle-linear" width="24" class="faq-icon shrink-0 text-exo-cyan"></iconify-icon></button><div class="faq-body"><p class="pb-7 pr-10 text-sm leading-relaxed text-white/60">Avec calme, methode et transparence. Je vous aide a comprendre la situation, a formuler les bons messages, a repondre de maniere professionnelle et a proteger votre reputation aupres du public et des medias.</p></div></div>
            <div class="faq-item reveal"><button class="faq-toggle flex w-full items-center justify-between gap-6 py-7 text-left" type="button"><span class="text-lg font-medium tracking-tight">Travaillez-vous avec les journalistes ?</span><iconify-icon icon="solar:add-circle-linear" width="24" class="faq-icon shrink-0 text-exo-cyan"></iconify-icon></button><div class="faq-body"><p class="pb-7 pr-10 text-sm leading-relaxed text-white/60">Oui. Je recherche pour vous les medias pertinents, cree des opportunites avec les journalistes, redige vos communiques et dossiers de presse et vous accompagne dans vos echanges pour maximiser vos chances d'etre publie(e).</p></div></div>
          </div>
        </section>

        <div class="section-line mx-auto h-px max-w-6xl"></div>

        <section id="contact" class="relative mx-auto max-w-6xl px-5 py-28 sm:px-8 md:py-40">
          <div class="reveal soft-panel relative overflow-hidden rounded-[2.4rem] border border-white/10 px-7 py-16 text-center shadow-[0_40px_120px_rgba(0,0,0,.55)] sm:px-12 md:py-28">
            <div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-[#bfeeff]/60 to-transparent"></div>
            <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-[#bfeeff]/10 blur-3xl"></div>
            <p class="text-[11px] font-bold uppercase tracking-[.26em] text-exo-cyan">Contact</p>
            <h2 class="mx-auto mt-7 max-w-4xl text-4xl font-medium leading-[1.02] tracking-tight sm:text-5xl md:text-7xl" style="letter-spacing:-.06em;">Et si vous me <span class="font-playfair italic font-normal">contactiez</span> maintenant ?</h2>
            <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-white/60">Discutons de vos objectifs de communication. Reponse sous 48h.</p>
            <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
              <a href="mailto:oriane.annen03@gmail.com" class="w-fit rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-black transition-all hover:scale-[1.03] hover:bg-[#effbff] hover:shadow-lg hover:shadow-[#bfeeff]/25 active:scale-95">Envoyer un email</a>
              <a href="https://linkedin.com" target="_blank" class="w-fit rounded-full border border-white/30 bg-transparent px-8 py-3.5 text-sm font-semibold text-white backdrop-blur transition-all hover:border-white/55 hover:bg-white/10 active:scale-95">Me suivre sur LinkedIn</a>
            </div>
            <div class="mt-10 text-center text-sm text-white/40">
              <p>Oriane Annen — Vy d'Echallens 1M, 1004 Lausanne, Suisse</p>
              <p class="mt-1">Brevet federal de specialiste en relations publiques</p>
            </div>
          </div>
        </section>

        <Footer />
      </div>
    </div>
  </main>
</Layout>
